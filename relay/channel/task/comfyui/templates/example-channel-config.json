{
  "_comment": "Paste this JSON into the channel's workflow_templates field. Provider is RunPod by default; change to other strategies when wired. Each top-level key under templates is a model the user can select (e.g. flux2-dev). Workflow JSON must be ComfyUI API format (Settings -> Dev Mode -> Save (API Format)). The params map binds logical request fields to node inputs by node ID. The `app` field carries the provider-specific endpoint id (RunPod serverless endpoint id, fal app slug, etc.).",
  "provider": "runpod",
  "app": "your-runpod-endpoint-id",
  "templates": {
    "flux2-dev": {
      "version": "1.0",
      "description": "Flux 2 dev fp8mixed, 1024x1024, 20 steps, guidance 4.0",
      "workflow": {
        "6": {
          "class_type": "CLIPTextEncode",
          "inputs": {
            "text": "",
            "clip": ["38", 0]
          }
        },
        "8": {
          "class_type": "VAEDecode",
          "inputs": {
            "samples": ["13", 0],
            "vae": ["10", 0]
          }
        },
        "9": {
          "class_type": "SaveImage",
          "inputs": {
            "filename_prefix": "comfyui",
            "images": ["8", 0]
          }
        },
        "10": {
          "class_type": "VAELoader",
          "inputs": {
            "vae_name": "flux2-vae.safetensors"
          }
        },
        "12": {
          "class_type": "UNETLoader",
          "inputs": {
            "unet_name": "flux2_dev_fp8mixed.safetensors",
            "weight_dtype": "default"
          }
        },
        "13": {
          "class_type": "SamplerCustomAdvanced",
          "inputs": {
            "noise": ["25", 0],
            "guider": ["22", 0],
            "sampler": ["16", 0],
            "sigmas": ["48", 0],
            "latent_image": ["47", 0]
          }
        },
        "16": {
          "class_type": "KSamplerSelect",
          "inputs": {
            "sampler_name": "euler"
          }
        },
        "22": {
          "class_type": "BasicGuider",
          "inputs": {
            "model": ["12", 0],
            "conditioning": ["26", 0]
          }
        },
        "25": {
          "class_type": "RandomNoise",
          "inputs": {
            "noise_seed": 0
          }
        },
        "26": {
          "class_type": "FluxGuidance",
          "inputs": {
            "guidance": 4.0,
            "conditioning": ["6", 0]
          }
        },
        "38": {
          "class_type": "CLIPLoader",
          "inputs": {
            "clip_name": "mistral_3_small_flux2_fp8.safetensors",
            "type": "flux2",
            "device": "default"
          }
        },
        "47": {
          "class_type": "EmptyFlux2LatentImage",
          "inputs": {
            "width": 1024,
            "height": 1024,
            "batch_size": 1
          }
        },
        "48": {
          "class_type": "Flux2Scheduler",
          "inputs": {
            "steps": 20,
            "width": 1024,
            "height": 1024
          }
        }
      },
      "params": {
        "prompt": { "node": "6",  "input": "text" },
        "seed":   { "node": "25", "input": "noise_seed", "auto_random": true },
        "steps":  { "node": "48", "input": "steps", "default": 20 },
        "cfg":    { "node": "26", "input": "guidance", "default": 4.0 }
      }
    },
    "flux2-dev-compose": {
      "version": "1.0",
      "description": "Flux 2 dev with multi-reference composition. Adapter clones the LoadImage / ImageScaleToTotalPixels / VAEEncode / ReferenceLatent placeholder per requested reference, chains ReferenceLatent.conditioning head-to-tail, rewires BasicGuider.conditioning to the tail clone. Zero references collapses the chain back to text-only (BasicGuider rewires to FluxGuidance).",
      "workflow": {
        "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "", "clip": ["38", 0] } },
        "8": { "class_type": "VAEDecode", "inputs": { "samples": ["13", 0], "vae": ["10", 0] } },
        "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "comfyui", "images": ["8", 0] } },
        "10": { "class_type": "VAELoader", "inputs": { "vae_name": "flux2-vae.safetensors" } },
        "12": { "class_type": "UNETLoader", "inputs": { "unet_name": "flux2_dev_fp8mixed.safetensors", "weight_dtype": "default" } },
        "13": { "class_type": "SamplerCustomAdvanced", "inputs": { "noise": ["25", 0], "guider": ["22", 0], "sampler": ["16", 0], "sigmas": ["48", 0], "latent_image": ["47", 0] } },
        "16": { "class_type": "KSamplerSelect", "inputs": { "sampler_name": "euler" } },
        "22": {
          "class_type": "BasicGuider",
          "inputs": {
            "model": ["12", 0],
            "_comment": "BasicGuider reads from the ReferenceLatent tail. Adapter rewires this back to ['26', 0] when zero references are requested.",
            "conditioning": ["39", 0]
          }
        },
        "25": { "class_type": "RandomNoise", "inputs": { "noise_seed": 0 } },
        "26": { "class_type": "FluxGuidance", "inputs": { "guidance": 4.0, "conditioning": ["6", 0] } },
        "38": { "class_type": "CLIPLoader", "inputs": { "clip_name": "mistral_3_small_flux2_fp8.safetensors", "type": "flux2", "device": "default" } },
        "39": { "class_type": "ReferenceLatent", "inputs": { "conditioning": ["26", 0], "latent": ["40", 0] } },
        "40": { "class_type": "VAEEncode", "inputs": { "pixels": ["41", 0], "vae": ["10", 0] } },
        "41": { "class_type": "ImageScaleToTotalPixels", "inputs": { "image": ["42", 0], "upscale_method": "area", "megapixels": 1, "resolution_steps": 1 } },
        "42": { "class_type": "LoadImage", "inputs": { "image": "" } },
        "47": { "class_type": "EmptyFlux2LatentImage", "inputs": { "width": 1024, "height": 1024, "batch_size": 1 } },
        "48": { "class_type": "Flux2Scheduler", "inputs": { "steps": 20, "width": 1024, "height": 1024 } }
      },
      "params": {
        "prompt": { "node": "6",  "input": "text" },
        "seed":   { "node": "25", "input": "noise_seed", "auto_random": true },
        "steps":  { "node": "48", "input": "steps", "default": 20 },
        "cfg":    { "node": "26", "input": "guidance", "default": 4.0 }
      },
      "references": {
        "loader_node": "42",
        "loader_input": "image",
        "scale_node": "41",
        "encode_node": "40",
        "ref_node": "39",
        "max_references": 6
      }
    },
    "comfyui-sdxl-txt2img-lora": {
      "version": "1.0",
      "description": "SDXL txt2img with LoRA stacking (multi-LoRA via lora_chain)",
      "workflow": {
        "3": {
          "class_type": "KSampler",
          "inputs": {
            "seed": 0,
            "steps": 25,
            "cfg": 7.0,
            "sampler_name": "euler",
            "scheduler": "normal",
            "denoise": 1.0,
            "model": ["10", 0],
            "positive": ["6", 0],
            "negative": ["7", 0],
            "latent_image": ["5", 0]
          }
        },
        "4": {
          "class_type": "CheckpointLoaderSimple",
          "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" }
        },
        "5": {
          "class_type": "EmptyLatentImage",
          "inputs": { "width": 1024, "height": 1024, "batch_size": 1 }
        },
        "6": {
          "class_type": "CLIPTextEncode",
          "inputs": { "text": "", "clip": ["10", 1] }
        },
        "7": {
          "class_type": "CLIPTextEncode",
          "inputs": { "text": "", "clip": ["10", 1] }
        },
        "8": {
          "class_type": "VAEDecode",
          "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
        },
        "9": {
          "class_type": "SaveImage",
          "inputs": { "filename_prefix": "comfyui", "images": ["8", 0] }
        },
        "10": {
          "class_type": "LoraLoader",
          "inputs": {
            "lora_name": "",
            "strength_model": 1.0,
            "strength_clip": 1.0,
            "model": ["4", 0],
            "clip": ["4", 1]
          }
        }
      },
      "params": {
        "prompt":          { "node": "6", "input": "text" },
        "negative_prompt": { "node": "7", "input": "text" },
        "seed":            { "node": "3", "input": "seed",  "auto_random": true },
        "steps":           { "node": "3", "input": "steps", "default": 25 },
        "cfg":             { "node": "3", "input": "cfg",   "default": 7.0 },
        "width":           { "node": "5", "input": "width",  "default": 1024 },
        "height":          { "node": "5", "input": "height", "default": 1024 }
      },
      "lora_chain": {
        "node": "10",
        "input": "lora_name",
        "weight_input": "strength_model",
        "clip_weight_input": "strength_clip"
      }
    }
  }
}
